<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gerador de Senhas Seguro</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: radial-gradient(circle at top right, #2e0854, #0a0a1e), 
                        linear-gradient(135px, #0d1b2a 0%, #1f0033 100%);
            padding: 20px;
        }

        .card {
            background: rgba(15, 12, 30, 0.75);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(138, 43, 226, 0.3);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5), 0 0 20px rgba(0, 210, 255, 0.1);
            padding: 30px;
            border-radius: 20px;
            width: 100%;
            max-width: 460px;
            color: #f1f1f1;
        }

        h1 {
            text-align: center;
            font-size: 1.7rem;
            margin-bottom: 25px;
            background: linear-gradient(45px, #00d2ff, #9b51e0);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 700;
        }

        .output-area {
            background: rgba(255, 255, 255, 0.04);
            padding: 16px;
            border-radius: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            border: 1px solid rgba(0, 210, 255, 0.2);
            transition: border 0.3s;
        }

        .output-area:hover {
            border-color: rgba(155, 81, 224, 0.5);
        }

        #password-display {
            font-family: 'Courier New', Courier, monospace;
            font-size: 1.25rem;
            font-weight: 600;
            color: #00d2ff;
            word-break: break-all;
            user-select: all;
            padding-right: 10px;
        }

        .btn-copy {
            background: rgba(155, 81, 224, 0.2);
            border: 1px solid #9b51e0;
            color: #e0b0ff;
            padding: 8px 14px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.85rem;
            transition: all 0.2s ease;
        }

        .btn-copy:hover {
            background: #9b51e0;
            color: white;
            box-shadow: 0 0 10px rgba(155, 81, 224, 0.4);
        }

        .option-group {
            display: flex;
            flex-direction: column;
            gap: 16px;
            margin-bottom: 30px;
        }

        .option {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.95rem;
            color: #cbd5e1;
        }

        input[type="number"] {
            background: #0f0c1e;
            border: 1px solid #5a189a;
            color: #00d2ff;
            padding: 6px 10px;
            border-radius: 6px;
            width: 70px;
            text-align: center;
            font-weight: bold;
            outline: none;
        }

        input[type="number"]:focus {
            border-color: #00d2ff;
        }

        input[type="checkbox"] {
            appearance: none;
            -webkit-appearance: none;
            width: 20px;
            height: 20px;
            border: 2px solid #5a189a;
            border-radius: 6px;
            background: #0f0c1e;
            cursor: pointer;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        input[type="checkbox"]:checked {
            background: #9b51e0;
            border-color: #00d2ff;
        }

        input[type="checkbox"]:checked::before {
            content: "✓";
            color: #fff;
            font-size: 12px;
            font-weight: bold;
        }

        .btn-generate {
            width: 100%;
            background: linear-gradient(135px, #00d2ff 0%, #9b51e0 100%);
            color: white;
            border: none;
            padding: 14px;
            font-size: 1.05rem;
            font-weight: 700;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(155, 81, 224, 0.2);
        }

        .btn-generate:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(0, 210, 255, 0.4);
        }

        .btn-generate:active {
            transform: translateY(1px);
        }
    </style>
</head>
<body>

    <div class="card">
        <h1>Gerador de Senha</h1>
        
        <div class="output-area">
            <span id="password-display">Gerar nova senha...</span>
            <button class="btn-copy" id="btn-copy">Copiar</button>
        </div>

        <div class="option-group">
            <div class="option">
                <label for="length">Comprimento da senha (8-32)</label>
                <input type="number" id="length" min="8" max="32" value="16">
            </div>
            <div class="option">
                <label for="uppercase">Incluir Letras Maiúsculas (A-Z)</label>
                <input type="checkbox" id="uppercase" checked>
            </div>
            <div class="option">
                <label for="lowercase">Incluir Letras Minúsculas (a-z)</label>
                <input type="checkbox" id="lowercase" checked>
            </div>
            <div class="option">
                <label for="numbers">Incluir Números (0-9)</label>
                <input type="checkbox" id="numbers" checked>
            </div>
            <div class="option">
                <label for="symbols">Incluir Símbolos (!@#$...)</label>
                <input type="checkbox" id="symbols" checked>
            </div>
        </div>

        <button class="btn-generate" id="btn-generate">Criar Senha Forte</button>
    </div>

    <script>
        const display = document.getElementById('password-display');
        const lengthInput = document.getElementById('length');
        const upperCheck = document.getElementById('uppercase');
        const lowerCheck = document.getElementById('lowercase');
        const numberCheck = document.getElementById('numbers');
        const symbolCheck = document.getElementById('symbols');
        const generateBtn = document.getElementById('btn-generate');
        const copyBtn = document.getElementById('btn-copy');

        const charSets = {
            upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
            lower: 'abcdefghijklmnopqrstuvwxyz',
            number: '0123456789',
            symbol: '!@#$%^&*()_+-=[]{}|;:,.<>?'
        };

        // Função para gerar números aleatórios seguros via API Criptográfica do Navegador
        function secureRandomInt(max) {
            const array = new Uint32Array(1);
            window.crypto.getRandomValues(array);
            return array[0] % max;
        }

        function generatePassword() {
            let length = parseInt(lengthInput.value);
            
            // Força limites seguros de tamanho
            if (isNaN(length) || length < 8) length = 8;
            if (length > 32) length = 32;
            lengthInput.value = length;

            let pool = '';
            let guaranteedChars = [];

            // Adiciona os tipos de caracteres escolhidos e garante pelo menos um de cada
            if (upperCheck.checked) {
                pool += charSets.upper;
                guaranteedChars.push(charSets.upper[secureRandomInt(charSets.upper.length)]);
            }
            if (lowerCheck.checked) {
                pool += charSets.lower;
                guaranteedChars.push(charSets.lower[secureRandomInt(charSets.lower.length)]);
            }
            if (numberCheck.checked) {
                pool += charSets.number;
                guaranteedChars.push(charSets.number[secureRandomInt(charSets.number.length)]);
            }
            if (symbolCheck.checked) {
                pool += charSets.symbol;
                guaranteedChars.push(charSets.symbol[secureRandomInt(charSets.symbol.length)]);
            }

            if (pool === '') {
                display.innerText = 'Selecione uma opção!';
                display.style.color = '#ff4d4d';
                return;
            }

            display.style.color = '#00d2ff';
            let passwordResult = [...guaranteedChars];

            // Preenche o restante do comprimento solicitado
            for (let i = passwordResult.length; i < length; i++) {
                const randomIndex = secureRandomInt(pool.length);
                passwordResult.push(pool[randomIndex]);
            }

            // Embaralha o resultado final usando algoritmo de Fisher-Yates seguro
            for (let i = passwordResult.length - 1; i > 0; i--) {
                const j = secureRandomInt(i + 1);
                [passwordResult[i], passwordResult[j]] = [passwordResult[j], passwordResult[i]];
            }

            display.innerText = passwordResult.join('');
        }

        generateBtn.addEventListener('click', generatePassword);

        copyBtn.addEventListener('click', () => {
            const currentTxt = display.innerText;
            if (!currentTxt || currentTxt === 'Gerar nova senha...' || currentTxt === 'Selecione uma opção!') return;

            navigator.clipboard.writeText(currentTxt).then(() => {
                const originalText = copyBtn.innerText;
                copyBtn.innerText = 'Copiado!';
                copyBtn.style.background = '#00d2ff';
                copyBtn.style.color = '#0a0a1e';
                copyBtn.style.borderColor = '#00d2ff';
                
                setTimeout(() => {
                    copyBtn.innerText = originalText;
                    copyBtn.style.background = '';
                    copyBtn.style.color = '';
                    copyBtn.style.borderColor = '';
